Step 2) sed -i 's/#$nrconf{restart} = '"'"'i'"'"';/$nrconf{restart} = '"'"'a'"'"';/g' /etc/needrestart/needrestart.conf
Step 3) sed -i 's/#$nrconf{kernelhints} = -1;/$nrconf{kernelhints} = -1;/g' /etc/needrestart/needrestart.conf
Step 4) apt install git vim htop unrar-free curl neofetch -y
Step 5) chmod -x /etc/update-motd.d/10-help-text
Step 6) chmod -x /etc/update-motd.d/50-motd-news
Step 7) nano /etc/update-motd.d/01-custom
Step 8) paste:
#!/bin/sh
/usr/bin/neofetch --color_blocks
HIGHEST_KERNEL=`find /boot/vmlinuz-* | sort -V | tail -n 1 | sed 's|.*vmlinuz-||'`
RUNNING_KERNEL=`uname -r`
echo "Highest Kernel: $HIGHEST_KERNEL
Running Kernel: $RUNNING_KERNEL"
if [ "$HIGHEST_KERNEL" != "$RUNNING_KERNEL" ]; then
  echo "** Reboot Required **"
fi
Step 9) ctrl+s and ctrl+x
Step 10) chmod +x /etc/update-motd.d/01-custom
Step 11) Reboot

